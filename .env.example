# Database
DATABASE_URL=mysql://user:password@localhost:3306/review_collect

# Auth / Sessions
JWT_SECRET=your-secret-key-at-least-32-chars
OWNER_OPEN_ID=your-owner-open-id

# OAuth (provided by the Manus platform or your own OAuth server)
OAUTH_SERVER_URL=https://your-oauth-server.example.com
VITE_APP_ID=your-app-id

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# AWS S3 (optional — for file/image uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name

# Internal Forge API (Manus platform only — leave blank if self-hosting)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
